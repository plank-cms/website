---
import type { NavProps } from "@/types";
import MobileMenu from "@/components/MobileMenu.astro";
import { ArrowUpRightIcon, StarIcon } from "@lucide/astro";
import { getMainNav } from "@/lib/plank/fetch";
import { getGithubStars } from "@/lib/github";
import { siGithub, siNpm } from "simple-icons";
import BrandIcon from "./BrandIcon.astro";

const mainNav: NavProps[] = await getMainNav();
const githubStars = await getGithubStars();
const githubRepo = import.meta.env.PUBLIC_GITHUB_REPO as string | undefined;
const githubRepoUrl = githubRepo ? `https://github.com/${githubRepo}` : null;
const starsLabel =
  typeof githubStars === "number"
    ? new Intl.NumberFormat("en", {
        notation: "compact",
        maximumFractionDigits: 1,
      }).format(githubStars)
    : null;
---

<header
  class="bg-black group-data-[variant=yellow]:bg-am-y group-data-[variant=light]:bg-white fixed top-0 left-0 right-0 z-50 max-w-7xl mx-auto w-full flex items-center justify-between p-4"
>
  <a href="/"
    ><img
      src="/plank-logo-w.svg"
      alt="Plank CMS Logo"
      width="32"
      title="Plank CMS"
      class="group-data-[variant=yellow]:brightness-0 group-data-[variant=light]:brightness-0"
    /></a
  >

  <nav
    aria-label="Main and social navigation (desktop)"
    class="hidden md:block"
  >
    <ul class="flex items-center space-x-6">
      {
        mainNav.map((opt) => {
          const isExternal = opt.href.startsWith("https");
          return (
            <li>
              <a
                href={opt.href}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener" : undefined}
                class="flex items-center uppercase hover:underline"
              >
                {opt.label}
                {isExternal && (
                  <ArrowUpRightIcon
                    size={20}
                    class="text-am-y group-data-[variant=yellow]:text-black group-data-[variant=light]:text-black shrink-0"
                  />
                )}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>

  {
    githubRepoUrl && starsLabel && (
      <a
        href={githubRepoUrl}
        target="_blank"
        rel="noopener"
        class="hidden md:flex items-center gap-2 uppercase hover:underline"
        aria-label={`GitHub stars: ${githubStars}`}
      >
        <BrandIcon icon={siGithub} size={20} />
        <span>{starsLabel}</span>
      </a>
    )
  }

  <div class="md:hidden">
    <MobileMenu
      items={mainNav}
      githubRepoUrl={githubRepoUrl}
      starsLabel={starsLabel}
    />
  </div>
</header>
<div class="pb-32"></div>
