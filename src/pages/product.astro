---
export const prerender = true;

import FeatureCard from "@/components/product/FeatureCard.astro";
import { ProseRenderer } from "@/components/ProseRenderer";
import GridContainer from "@/layouts/GridContainer.astro";
import RootLayout from "@/layouts/RootLayout.astro";
import { getProduct } from "@/lib/plank/fetch";

const product = await getProduct();
const title = "Product";
---

<RootLayout
  title={`${title} - Plank CMS`}
  description="A self-hosted headless CMS you can deploy in minutes"
  image="https://plank-cms.com/og-image.png"
  url="https://plank-cms.com/product"
>
  <h1 class="sr-only">{title}</h1>
  <GridContainer class="md:items-center min-h-dvh mt-4 md:-mt-32">
    <div class="col-span-full">
      <div class="w-full flex flex-col justify-center gap-8 max-w-4xl mx-auto">
        <h2
          class="font-bold text-6xl md:text-7xl xl:text-8xl md:text-center uppercase"
        >
          {product.title}
        </h2>
        <div class="text-muted-foreground md:text-center">
          <ProseRenderer content={product.description ?? ""} />
        </div>
      </div>
    </div>
  </GridContainer>

  <GridContainer gap="gap-0 mb-16">
    <div class="col-span-full md:text-center mb-4">
      <h2 class="font-bold text-3xl uppercase">Plank Features</h2>
    </div>
    {
      (product.features ?? []).map((feature, index) => (
        <div class="col-span-2">
          <FeatureCard
            number={String(index + 1).padStart(2, "0")}
            label={feature.label ?? ""}
            description={feature.description ?? ""}
          />
        </div>
      ))
    }
  </GridContainer>

  <GridContainer gap="gap-0 mb-16">
    <div class="col-span-full md:text-center mb-4">
      <h2 class="font-bold text-3xl uppercase">Special Modes</h2>
    </div>
    {
      (product.special_modes ?? []).map((mode, index) => (
        <div class="col-span-2">
          <FeatureCard
            number={String(index + 1).padStart(2, "0")}
            label={mode.label ?? ""}
            description={mode.description ?? ""}
          />
        </div>
      ))
    }
  </GridContainer>
</RootLayout>
