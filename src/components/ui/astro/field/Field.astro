---
import { cn } from "@/lib/utils";

type Orientation = "vertical" | "horizontal" | "responsive";

interface Props {
  class?: string;
  orientation?: Orientation;
  [key: string]: any;
}

const { class: className, orientation = "vertical", ...props } = Astro.props as Props;

const orientationClasses: Record<Orientation, string> = {
  vertical: "flex-col *:w-full [&>.sr-only]:w-auto",
  horizontal:
    "flex-row items-center has-[>[data-slot=field-content]]:items-start *:data-[slot=field-label]:flex-auto has-[>[data-slot=field-content]]:[&>[role=checkbox],[role=radio]]:mt-px",
  responsive:
    "flex-col *:w-full @md/field-group:flex-row @md/field-group:items-center @md/field-group:*:w-auto @md/field-group:has-[>[data-slot=field-content]]:items-start @md/field-group:*:data-[slot=field-label]:flex-auto [&>.sr-only]:w-auto @md/field-group:has-[>[data-slot=field-content]]:[&>[role=checkbox],[role=radio]]:mt-px",
};
---

<div
  role="group"
  data-slot="field"
  data-orientation={orientation}
  class={cn(
    "group/field flex w-full gap-3 data-[invalid=true]:text-destructive",
    orientationClasses[orientation],
    className,
  )}
  {...props}
>
  <slot />
  {
    Astro.slots.has("label") && (
      <label
        data-slot="field-label"
        class="group/field-label peer/field-label flex w-fit gap-2 leading-snug select-none group-data-[disabled=true]/field:opacity-50 has-data-checked:border-primary/20 has-data-checked:bg-primary/10 has-[>[data-slot=field]]:rounded-xl has-[>[data-slot=field]]:border *:data-[slot=field]:p-4 group-data-[variant=light]:has-data-checked:border-primary/30 group-data-[variant=light]:has-data-checked:bg-primary/5 group-data-[variant=yellow]:has-data-checked:border-primary/30 group-data-[variant=yellow]:has-data-checked:bg-primary/5 has-[>[data-slot=field]]:w-full has-[>[data-slot=field]]:flex-col"
      >
        <slot name="label" />
      </label>
    )
  }
</div>
