---
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className, ...props } = Astro.props as Props;
---

<textarea
  data-slot="textarea"
  class={cn(
    "flex field-sizing-content min-h-16 w-full resize-none rounded-xl border border-input bg-input/30 px-3 py-3 text-base transition-colors outline-none placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:border-destructive/50 aria-invalid:ring-[3px] aria-invalid:ring-destructive/40 md:text-sm",
    className,
  )}
  {...props}
></textarea>
