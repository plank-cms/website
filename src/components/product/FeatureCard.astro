---
import Card from "@/components/ui/astro/Card.astro";
import type { FeatureCardProp } from "@/types";

type Props = FeatureCardProp;

const { number, label, description } = Astro.props;
---

<Card class="aspect-square h-full justify-between">
  <div slot="content">
    <p class="mb-2">{number}</p>
    <h3 class="text-2xl font-bold uppercase">{label}</h3>
  </div>
  <p slot="footer" class="text-xs text-left">{description}</p>
</Card>
