---
export const prerender = true;

import FeaturedClients from "@/components/home/FeaturedClients.astro";
import Hero from "@/components/home/Hero.astro";
import RootLayout from "@/layouts/RootLayout.astro";
import { getHome } from "@/lib/plank/fetch";
import type { LogoTileProps } from "@/types";

const home = await getHome();

const featuredClients: LogoTileProps[] = (home.feat_clients ?? []).flatMap(
  (client) => {
    if (!client.logo || !client.title) return [];

    return [
      {
        logo: client.logo,
        title: client.title,
        href: client.href,
      },
    ];
  },
);
---

<RootLayout
  title="Plank CMS"
  description="A self-hosted headless CMS you can deploy in minutes"
  image="https://plank-cms.com/og-image.png"
  url="https://plank-cms.com"
>
  <Hero title={home.title} description={home.description} cta={home.cta} />
  <FeaturedClients clients={featuredClients} />
</RootLayout>
