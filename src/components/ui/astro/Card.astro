---
import { cn } from "@/lib/utils";

interface Props {
  class?: string;
  size?: "default" | "sm";
  [key: string]: any;
}

const { class: className, size = "default", ...props } = Astro.props as Props;
---

<div
  data-slot="card"
  data-size={size}
  class={cn(
    "group/card flex flex-col gap-6 overflow-hidden rounded-2xl bg-card py-6 text-sm text-card-foreground ring-1 ring-foreground/10 has-[>img:first-child]:pt-0 data-[size=sm]:gap-4 data-[size=sm]:py-4",
    className,
  )}
  {...props}
>
  {
    Astro.slots.has("content") && (
      <div
        data-slot="card-content"
        class="px-6 group-data-[size=sm]/card:px-4"
      >
        <slot name="content" />
      </div>
    )
  }
  {
    Astro.slots.has("footer") && (
      <div
        data-slot="card-footer"
        class="flex items-center px-6 group-data-[size=sm]/card:px-4 [.border-t]:pt-6 group-data-[size=sm]/card:[.border-t]:pt-4"
      >
        <slot name="footer" />
      </div>
    )
  }
  <slot />
</div>
